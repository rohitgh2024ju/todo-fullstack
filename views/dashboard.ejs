<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>TaskFlow Dashboard</title>
    <link rel="icon" href="/logo.svg" type="image/svg+xml">

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display&family=Inter:wght@400;500;600&display=swap"
        rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .logo-font {
            font-family: 'Playfair Display', serif;
        }
    </style>
</head>

<body class="bg-[#f5f1eb] text-gray-800">

    <!-- HEADER -->
    <header class="flex justify-between items-center px-12 py-6 border-b">
        <div class="flex items-center gap-3">
            <img src="/logo.svg" alt="Logo" class="w-10 h-10">

            <h1 class="logo-font text-4xl italic">TaskFlow</h1>

        </div>

        <div class="flex gap-4">
            <button onclick="deleteAccount()" class="px-6 py-2 border border-red-400 text-red-500 hover:bg-red-50">
                DELETE ACCOUNT
            </button>

            <a href="/logout" class="px-6 py-2 bg-black text-white hover:bg-gray-800">
                LOGOUT
            </a>
        </div>
    </header>

    <main class="flex">

        <!-- SIDEBAR -->
        <aside class="w-[260px] border-r px-10 py-10">
            <p class="text-xs tracking-widest text-gray-400 mb-2">USER</p>
            <h2 class="text-2xl font-semibold mb-6">
                <%= username %>
            </h2>

            <hr class="mb-6">

            <div class="space-y-8">
                <div>
                    <p class="text-gray-400 text-sm">Total Tasks</p>
                    <h1 id="total" class="text-5xl font-serif">0</h1>
                </div>

                <div>
                    <p class="text-gray-400 text-sm">Remains</p>
                    <h1 id="pending" class="text-5xl font-serif text-[#c26a4f]">0</h1>
                </div>

                <div>
                    <p class="text-gray-400 text-sm">Completed</p>
                    <h1 id="completed" class="text-5xl font-serif text-green-500">0</h1>
                </div>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <section class="flex-1 px-16 py-10">

            <!-- DATE -->
            <p id="date" class="text-gray-500 text-lg mb-10"></p>

            <!-- CREATE TASK -->
            <!-- CREATE TASK -->
            <h3 class="text-xs tracking-widest text-gray-400 mb-4">
                CREATE NEW TASK
            </h3>

            <form onsubmit="handleSubmit(event)" class="space-y-4 mb-10">

                <input id="titleInput" placeholder="What needs to be done?"
                    class="w-full p-4 bg-white border outline-none" required />

                <div class="flex gap-4">
                    <input id="deadlineInput" type="date" class="flex-1 p-4 bg-white border outline-none" required />

                    <button type="submit" class="px-8 bg-[#c26a4f] text-white font-semibold">
                        ADD
                    </button>
                </div>

            </form>

            <hr class="mb-8">

            <!-- TASK LIST -->
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xs tracking-widest text-gray-400 uppercase ml-2" id="all-tasks">
                    ALL TASKS (0)
                </h3>

                <button onclick="deleteAllTasks()" class="text-sm text-red-500 hover:underline mr-2">
                    DELETE ALL
                </button>
            </div>

            <div id="taskList" class="space-y-6"></div>

        </section>
    </main>

    <script>
        /* ========= INIT DATE ========= */
        document.getElementById('date').innerText =
            new Date().toLocaleDateString("en-IN", {
                weekday: "long",
                day: "numeric",
                month: "long",
                year: "numeric"
            });

        /* ========= HELPERS ========= */
        function formatDate(date) {
            const d = new Date(date);
            const today = new Date();
            today.setHours(0, 0, 0, 0);

            const diff = Math.ceil((d - today) / (1000 * 60 * 60 * 24));

            if (diff === 0) return "Today";
            if (diff < 0) return "Overdue";

            return d.toLocaleDateString();
        }

        /* ========= CREATE TASK ELEMENT ========= */
        function createTaskElement(task) {
            const isCompleted = task.status === 'completed';

            const div = document.createElement('div');
            div.className = "bg-white border p-6 flex justify-between items-center";

            div.innerHTML = `
                <div class="flex items-start gap-4">
                    <input 
                        type="checkbox"
                        ${isCompleted ? 'checked' : ''}
                        class="checkbox w-5 h-5 accent-[#c26a4f] cursor-pointer mt-1"
                    />

                    <div>
                        <p class="title text-lg font-medium 
                            ${isCompleted ? 'line-through opacity-60' : ''}">
                            ${task.title}
                        </p>

                        <p class="text-sm mt-2 
                            ${formatDate(task.deadline) === 'Overdue' ? 'text-red-500' : 'text-gray-500'}">
                            ${formatDate(task.deadline) === 'Overdue'
                    ? 'Overdue: Today'
                    : formatDate(task.deadline)}
                        </p>
                    </div>
                </div>

                <button class="delete text-[#c26a4f]">Delete</button>
            `;

            const checkbox = div.querySelector('.checkbox');
            const title = div.querySelector('.title');
            const deleteBtn = div.querySelector('.delete');

            checkbox.addEventListener('change', () => toggleTask(task._id, title));
            deleteBtn.addEventListener('click', () => deleteTask(task._id, div));

            return div;
        }

        /* ========= FETCH TASKS ========= */
        async function fetchTasks() {
            const res = await fetch('/tasks/fetch');
            const tasks = await res.json();

            const list = document.getElementById('taskList');
            list.innerHTML = '';

            tasks.forEach(task => {
                list.appendChild(createTaskElement(task));
            });
        }

        /* ========= FETCH COUNTS ========= */
        async function fetchCounts() {
            const res = await fetch('/tasks/count');
            if (!res.ok) return;

            const data = await res.json();

            document.getElementById('total').innerText = data.total || 0;
            document.getElementById('pending').innerText = data.pending || 0;
            document.getElementById('completed').innerText = data.completed || 0;
            document.getElementById('all-tasks').innerText = `ALL TASKS (${data.total})`;
        }

        /* ========= FORM HANDLER ========= */
        function handleSubmit(e) {
            e.preventDefault(); // stop reload
            addTask();
        }

        /* ========= ADD TASK ========= */
        async function addTask() {
            const titleInput = document.getElementById('titleInput');
            const deadlineInput = document.getElementById('deadlineInput');

            const title = titleInput.value.trim();
            const deadline = deadlineInput.value;

            // extra safety (optional but good)
            if (!title || !deadline) return;

            await fetch('/tasks/create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ title, deadline })
            });

            titleInput.value = '';
            deadlineInput.value = '';

            fetchTasks();
            fetchCounts();
        }
        /* ========= TOGGLE TASK ========= */
        async function toggleTask(id, titleEl) {
            await fetch(`/tasks/toggle/${id}`, { method: 'PATCH' });

            titleEl.classList.toggle('line-through');
            titleEl.classList.toggle('opacity-60');

            fetchCounts();
        }

        /* ========= DELETE TASK ========= */
        async function deleteTask(id, element) {
            await fetch(`/tasks/delete/${id}`, { method: 'DELETE' });

            element.remove();
            fetchCounts();
        }

        /* ========= DELETE ACCOUNT ========= */
        async function deleteAccount() {

            // First confirmation
            const confirmed = confirm("Are you sure you want to delete your account?");
            if (!confirmed) return;

            // Final warning
            const finalCheck = confirm(
                "⚠️ This will permanently delete ALL your data.\n\nThis action cannot be undone.\n\nContinue?"
            );
            if (!finalCheck) return;

            try {
                const res = await fetch('/tasks/deleteAccount', {
                    method: 'DELETE'
                });

                if (!res.ok) {
                    alert("Something went wrong. Please try again.");
                    return;
                }

                alert("Your account has been deleted.");

                // redirect to login
                window.location.href = '/login';

            } catch (err) {
                console.error(err);
                alert("Error deleting account.");
            }
        }

        /*======= DELETE ALL TASKS ======*/
        async function deleteAllTasks() {

            const confirmDelete = confirm(
                "⚠️ This will delete ALL your tasks.\n\nThis action cannot be undone.\n\nContinue?"
            );

            if (!confirmDelete) return;

            await fetch('/tasks/deleteAll', {
                method: 'DELETE'
            });

            fetchTasks();
            fetchCounts();
        }

        /* ========= INIT ========= */
        fetchTasks();
        fetchCounts();
    </script>

</body>

</html>