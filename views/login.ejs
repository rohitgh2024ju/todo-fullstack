<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>TaskFlow Login</title>
    <link rel="icon" href="/logo.svg" type="image/svg+xml">
    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display&family=Inter:wght@400;500;600&display=swap"
        rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .logo-font {
            font-family: 'Playfair Display', serif;
        }
    </style>
</head>

<body class="bg-[#f5f5f5]">

    <!-- HEADER -->
    <div class="text-center py-10 bg-white border-b">
        <div class="flex items-center justify-center gap-3">
            <img src="/logo.svg" alt="Logo" class="w-10 h-10">

            <h1 class="logo-font text-4xl italic">TaskFlow</h1>

        </div>
        <p class="text-gray-500 mt-2">Join us and get started</p>
    </div>

    <!-- CARD -->
    <div class="flex justify-center items-center mt-20">
        <div class="bg-white p-10 rounded-2xl shadow-md w-[400px]">

            <h2 class="text-2xl font-semibold text-center mb-6">Login</h2>

            <form id="loginForm" class="space-y-4">

                <input type="email" name="email" placeholder="Enter email" required
                    class="w-full p-3 border rounded-lg bg-gray-100 outline-none" />

                <input type="password" name="password" placeholder="Enter password" required
                    class="w-full p-3 border rounded-lg bg-gray-100 outline-none" />

                <button type="submit" class="w-full py-3 bg-blue-500 text-white rounded-lg hover:bg-blue-600">
                    Login
                </button>

            </form>

            <p class="text-sm text-center mt-4 text-gray-500">
                Don't have an account?
                <a href="/signup" class="text-blue-500">Sign up</a>
            </p>
            <p id="login-result"
                class="text-center text-sm mt-3 font-medium text-green-600 transition-all duration-200"></p>
        </div>
    </div>

    <script>
        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData);

            const res = await fetch('/auth/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data),
                credentials: 'include'
            });

            if (res.ok) {
                document.getElementById('login-result').innerText = 'Login successful';

                setTimeout(() => {
                    window.location.href = '/dashboard';
                }, 2000)
            } else {
                alert("Login failed");
            }
        });
    </script>

</body>

</html>